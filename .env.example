# ==========================================
# MindFlow 环境变量配置模板 (zjhdml.online)
# 复制为 .env 后按需修改，严禁提交 .env 文件
# ==========================================

# ---- 部署环境 ----
NODE_ENV=development
APP_NAME=mindflow
APP_PORT=3000
APP_HOST=0.0.0.0

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindmap
DB_USER=postgres
DB_PASSWORD=change-me

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Elasticsearch ----
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=

# ---- 对象存储 (S3 兼容) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=mindmap-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- HSM 硬件加密 ----
HSM_ENABLED=false
HSM_MODULE_PATH=/usr/lib/softhsm/libsofthsm2.so
HSM_SLOT_ID=0
HSM_PIN=123456

# ---- Vault 密钥管理 ----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_ENABLED=false

# ---- AI 服务 ----
AI_API_ENDPOINT=https://api.openai.com/v1
AI_API_KEY=sk-change-me
AI_MODEL=gpt-4
AI_RATE_LIMIT_PER_USER=5
AI_GLOBAL_QPS=50

# ---- 安全加密 ----
ENCRYPTION_KEY=change-me-to-256-bit-key-minimum
TLS_CERT_PATH=/etc/certs/server.crt
TLS_KEY_PATH=/etc/certs/server.key

# ---- JWT 认证 ----
JWT_SECRET=change-me-to-secure-random-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ---- 跨境合规 ----
CROSS_BORDER_BLOCK_ENABLED=true
ALLOWED_COUNTRY_WHITELIST=CN
ALLOWED_IP_WHITELIST=

# ---- 水印 ----
WATERMARK_FORCE_ON_SECURE=true
WATERMARK_DEFAULT_DENSITY=medium

# ---- 日志 ----
LOG_LEVEL=debug
LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=-1

# ---- 前端 ----
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_APP_TITLE=MindFlow 思维导图

# ---- Supabase (BaaS) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- 协同 ----
YJS_SYNC_INTERVAL=200
YJS_MAX_DOC_SIZE_MB=100
